{
  "name": "@ordius/adonisjs-cursor-pagination",
  "version": "1.0.6",
  "description": "Cursor-based pagination for AdonisJS Lucid ORM",
  "engines": {
    "node": ">=20.6.0"
  },
  "main": "build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "imports": {
    "#models/*": "./models/*.js"
  },
  "exports": {
    ".": {
      "import": "./build/index.js",
      "require": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./types": {
      "import": "./build/src/cursor_paginator/types.js",
      "types": "./build/src/cursor_paginator/types.d.ts"
    },
    "./provider": "./build/providers/lucid_cursor_pagination_provider.js"
  },
  "scripts": {
    "clean": "del-cli build",
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "quick:test": "node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "test:pg": "DB_CONNECTION=pg node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "prebuild": "npm run lint && npm run clean",
    "build": "tsc",
    "postbuild": "npm run copy:templates",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:beta": "release-it --preRelease=beta",
    "release:alpha": "release-it --preRelease=alpha",
    "release:dry": "release-it --dry-run",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "adonisjs",
    "lucid",
    "cursor",
    "pagination",
    "paginator",
    "cursor-pagination",
    "cursor-paginator"
  ],
  "author": "Mixxtor",
  "license": "MIT",
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/core": "^6.19.0",
    "@adonisjs/eslint-config": "^2.1.2",
    "@adonisjs/lucid": "^21.6.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^1.4.1",
    "@japa/assert": "^4.1.1",
    "@japa/runner": "^4.4.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@swc/core": "^1.15.18",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^7.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.34.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.0.0 || ^7.0.0",
    "@adonisjs/lucid": "^21.0.0 || ^22.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/lucid": {
      "optional": false
    }
  },
  "homepage": "https://github.com/ordius/adonisjs-cursor-pagination#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ordius/adonisjs-cursor-pagination.git"
  },
  "bugs": {
    "url": "https://github.com/ordius/adonisjs-cursor-pagination/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "requireCleanWorkingDir": false,
      "requireUpstream": false,
      "push": true,
      "pushArgs": [
        "--follow-tags"
      ]
    },
    "github": {
      "release": true,
      "releaseName": "Release v${version}",
      "releaseNotes": null,
      "autoGenerate": true,
      "draft": false,
      "preRelease": false
    },
    "npm": {
      "publish": true,
      "publishPath": ".",
      "access": "public",
      "otp": false
    },
    "hooks": {
      "before:init": [
        "npm run lint",
        "npm run typecheck"
      ],
      "after:bump": [
        "npm run build"
      ],
      "before:release": [
        "npm test"
      ],
      "after:release": [
        "echo 🎉 Release ${version} completed successfully!"
      ]
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "✨ Features"
            },
            {
              "type": "fix",
              "section": "🐛 Bug Fixes"
            },
            {
              "type": "perf",
              "section": "⚡ Performance Improvements"
            },
            {
              "type": "refactor",
              "section": "♻️ Code Refactoring"
            },
            {
              "type": "docs",
              "section": "📚 Documentation"
            },
            {
              "type": "test",
              "section": "🧪 Tests"
            },
            {
              "type": "build",
              "section": "🏗️ Build System"
            },
            {
              "type": "ci",
              "section": "👷 CI/CD"
            },
            {
              "type": "chore",
              "section": "🔧 Maintenance"
            }
          ]
        },
        "infile": "CHANGELOG.md",
        "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\n"
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "adonisjs": {
    "types": "@ordius/adonisjs-cursor-pagination",
    "providers": [
      "@ordius/adonisjs-cursor-pagination/provider"
    ]
  }
}
